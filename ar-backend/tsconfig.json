{
	"compilerOptions": {
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"target": "ESNext",
		"rootDir": "./src",
		"outDir": "./dist",
		"types": ["node"],
		"strict": true,
		"sourceMap": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist"]
}
